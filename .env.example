# ─── Supabase (auto-injected into Edge Functions — do not set manually) ────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Anthropic / Claude ────────────────────────────────────────────────────────
# Required for enrich-ai function
ANTHROPIC_API_KEY=sk-ant-...

# ─── NYC Open Data ────────────────────────────────────────────────────────────
# Optional but strongly recommended — raises rate limits significantly
# Register at: https://data.cityofnewyork.us/profile/app_tokens
NYC_OPEN_DATA_APP_TOKEN=

# ─── Make.com Security ────────────────────────────────────────────────────────
# Set this in both Make.com HTTP headers and Supabase Edge Function secrets.
# Any random 32+ char string works: openssl rand -hex 32
MAKE_WEBHOOK_SECRET=

# Make.com outbound webhook that receives notification payloads (email/SMS routing)
# Create a "Custom Webhook" scenario in Make.com and paste its URL here.
MAKE_NOTIFY_WEBHOOK=https://hook.us2.make.com/...

# ─── ISA Lead Pipeline ────────────────────────────────────────────────────────
# Apify API token — used by Make.com to run scraping actors
# Get it at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...

# Make.com webhook for ISA lead notifications (separate from property notifications)
# Create a "Custom Webhook" scenario in Make.com for the ISA Notifications Router
MAKE_ISA_WEBHOOK=https://hook.us2.make.com/...
